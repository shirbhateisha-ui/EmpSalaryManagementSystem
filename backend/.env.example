# Server
NODE_ENV=development
PORT=4000

# CORS — allowed frontend origin
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=./data/app.db

# Auth tokens (use strong secrets in production)
ACCESS_TOKEN_SECRET=dev-access-token-secret-min-16chars
REFRESH_TOKEN_SECRET=dev-refresh-token-secret-min-16
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Seed admin user (Phase 1)
ADMIN_EMAIL=admin@acme.com
ADMIN_PASSWORD=i
ADMIN_NAME=System Admin
